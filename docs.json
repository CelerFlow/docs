{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "CelerFlow",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/agents",
              "concepts/workspaces",
              "concepts/tracing",
              "concepts/service-permissions",
              "concepts/human-approval",
              "concepts/agent-score",
              "concepts/health-checks",
              "concepts/risk-alerts"
            ]
          },
          {
            "group": "Integration",
            "pages": [
              "integration/openclaw-plugin",
              "integration/mcp-gateway",
              "integration/cli",
              "integration/notifications"
            ]
          },
          {
            "group": "Dashboard",
            "pages": [
              "dashboard/workspace-overview",
              "dashboard/agents",
              "dashboard/tracing"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/billing",
              "platform/teams-rbac",
              "platform/audit-export",
              "platform/roadmap"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Agent",
            "pages": [
              "api-reference/agent/register",
              "api-reference/agent/health",
              "api-reference/agent/terminate",
              "api-reference/agent/disconnect",
              "api-reference/agent/remove",
              "api-reference/agent/policies",
              "api-reference/agent/confirmations"
            ]
          },
          {
            "group": "Workspace",
            "pages": [
              "api-reference/fleet/create",
              "api-reference/fleet/list",
              "api-reference/fleet/get",
              "api-reference/fleet/delete"
            ]
          },
          {
            "group": "Trace",
            "pages": [
              "api-reference/trace/ingest",
              "api-reference/trace/query"
            ]
          },
          {
            "group": "Auth",
            "pages": [
              "api-reference/auth/device-code",
              "api-reference/auth/device-token",
              "api-reference/auth/setup-code",
              "api-reference/auth/rotate-token"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://celerflow.ai/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://celerflow.vercel.app"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/celerflow"
    }
  }
}
