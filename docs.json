{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Celerflow",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/agents",
              "concepts/fleets",
              "concepts/policies",
              "concepts/traces",
              "concepts/health-checks"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/cli-setup",
              "guides/connect-agent",
              "guides/mcp-proxy",
              "guides/dashboard"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/billing",
              "platform/teams-rbac",
              "platform/audit-export"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Fleet management",
            "pages": [
              "api-reference/fleet/create-fleet",
              "api-reference/fleet/list-fleets",
              "api-reference/fleet/get-fleet",
              "api-reference/fleet/delete-fleet"
            ]
          },
          {
            "group": "Agent operations",
            "pages": [
              "api-reference/agent/register-agent",
              "api-reference/agent/report-health",
              "api-reference/agent/get-health-checks",
              "api-reference/agent/disconnect-agent",
              "api-reference/agent/remove-agent"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              "api-reference/auth/device-code",
              "api-reference/auth/device-token",
              "api-reference/auth/setup-code",
              "api-reference/auth/rotate-token"
            ]
          },
          {
            "group": "Billing",
            "pages": [
              "api-reference/billing/usage"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/CelerFlow",
          "icon": "github"
        },
        {
          "anchor": "Blog",
          "href": "https://celerflow.ai/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@celerflow.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://celerflow.vercel.app"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/celerflow",
      "github": "https://github.com/CelerFlow"
    }
  }
}
